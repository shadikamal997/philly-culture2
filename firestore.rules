rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================
    // HELPER FUNCTIONS
    // =============================

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "superadmin", "owner"];
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // =============================
    // USERS
    // =============================
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can create their own profile on first sign-up
      // Allow role field on creation (needed for initial setup)
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == request.auth.token.email;
      
      // Users can update their own profile but NOT the role field
      allow update: if isAuthenticated() 
                    && request.auth.uid == userId
                    && !("role" in request.writeFields); // Prevent role modification after creation
      
      allow delete: if false;
    }

    // =============================
    // PROGRAMS (Academy Courses)
    // =============================
    match /programs/{programId} {
      // Anyone can read published programs
      allow read: if resource.data.published == true || isAdmin();
      
      // Only admins can create/update/delete
      allow create, update, delete: if isAdmin();
    }

    // =============================
    // COURSES
    // =============================
    match /courses/{courseId} {
      // Anyone can read published course metadata
      allow read: if resource.data.published == true || isAdmin();
      
      // Only admins can create/update/delete
      allow create, update, delete: if isAdmin();
      
      // Course lessons subcollection
      match /lessons/{lessonId} {
        // Only enrolled users or admins can access lessons
        allow read: if isAdmin() 
                    || (isAuthenticated() 
                        && courseId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.purchasedCourses);
        
        // Only admins can manage lessons
        allow create, update, delete: if isAdmin();
      }
    }

    // =============================
    // USER COURSE PROGRESS
    // =============================
    match /users/{userId}/courseProgress/{courseId} {
      // Users can read their own progress
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can update their own progress if they're enrolled
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId
                   && courseId in get(/databases/$(database)/documents/users/$(userId)).data.purchasedCourses;
    }

    // =============================
    // ENROLLMENTS (Student Purchases)
    // =============================
    match /enrollments/{enrollmentId} {
      // Users can read their own enrollments; admins can read all
      allow read: if isAuthenticated() 
                  && (resource.data.userEmail == request.auth.token.email || isAdmin());
      
      // Only backend creates enrollments (via webhook)
      allow create: if false;
      
      // Only backend or admin can update
      allow update: if isAdmin();
      
      allow delete: if false;
    }

    // =============================
    // WEBHOOK EVENTS (Idempotency)
    // =============================
    match /webhookEvents/{eventId} {
      // No client access - backend only
      allow read, write: if false;
    }

    // =============================
    // ADMIN LOGS (Audit Trail)
    // =============================
    match /adminLogs/{logId} {
      // Only admins can read audit logs
      allow read: if isAdmin();
      
      // No client writes - backend only
      allow write: if false;
    }

    // =============================
    // LEGACY COLLECTIONS (Deprecated)
    // =============================
    match /orders/{orderId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tools/{toolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // =============================
    // PROGRAM REVIEWS
    // =============================
    match /programReviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;

      // Only backend creates reviews (via API route which checks enrollment)
      allow create: if false;

      // Only backend deletes reviews
      allow delete: if false;

      allow update: if false;
    }

    match /carts/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // =============================
    // CHATS (Student-Admin Communication)
    // =============================
    match /chats/{chatId} {
      // Users can read chats they're a participant in (using email or UID)
      allow read: if isAuthenticated() 
                  && (request.auth.uid in resource.data.participants 
                      || request.auth.token.email in resource.data.participants 
                      || isAdmin());
      
      // Only backend creates chats (on enrollment)
      allow create: if false;
      
      // Participants can update (for marking as read)
      allow update: if isAuthenticated() 
                    && (request.auth.uid in resource.data.participants 
                        || request.auth.token.email in resource.data.participants);
      
      allow delete: if false;
    }

    // =============================
    // MESSAGES (Chat Messages)
    // =============================
    match /messages/{messageId} {
      // Users can read messages in their chats (using email or UID)
      allow read: if isAuthenticated() 
                  && exists(/databases/$(database)/documents/chats/$(resource.data.chatId))
                  && (request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants 
                      || request.auth.token.email in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants 
                      || isAdmin());
      
      // Users can create messages in their chats (using email or UID)
      allow create: if isAuthenticated() 
                    && exists(/databases/$(database)/documents/chats/$(request.resource.data.chatId))
                    && (request.auth.uid in get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants 
                        || request.auth.token.email in get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants)
                    && request.resource.data.senderId == request.auth.uid;
      
      // Users can update their own messages (for marking as read)
      allow update: if isAuthenticated();
      
      allow delete: if false;
    }
  }
}
