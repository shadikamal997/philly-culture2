rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================
    // HELPER FUNCTIONS
    // =============================

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isLessonAccessible(resourceData) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          resourceData.isPreview == true
          ||
          resourceData.courseId in
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.purchasedCourses
        );
    }

    // =============================
    // USERS
    // =============================
    match /users/{userId} {

      allow read: if request.auth != null 
                  && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !("role" in request.resource.data)
                    && !("purchasedCourses" in request.resource.data);

      allow delete: if false;

      match /addresses/{addressId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      match /certificates/{certId} {
        allow read: if request.auth != null
                    && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // =============================
    // COURSES
    // =============================
    match /courses/{courseId} {

      allow read: if resource.data.published == true;

      allow write: if isAdmin();
    }

    // =============================
    // LESSONS
    // =============================
    match /lessons/{lessonId} {

      allow read: if isLessonAccessible(resource.data);

      allow write: if isAdmin();
    }

    // =============================
    // PRODUCTS
    // =============================
    match /products/{productId} {

      allow read: if true;

      allow write: if isAdmin();
    }

    // =============================
    // ORDERS
    // =============================
    match /orders/{orderId} {

      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;

      allow create: if false; // Only backend creates

      allow update: if false; // Only backend updates

      allow delete: if false;
    }

    // =============================
    // REVIEWS
    // =============================
    match /reviews/{reviewId} {

      allow read: if true;

      allow create: if request.auth != null;

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // =============================
    // CARTS
    // =============================
    match /carts/{userId} {

      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
